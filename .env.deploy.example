# ============================================================================
# Coolify deploy için env şablonu — her servise ayrı set yapıştırılır.
# Bu dosya örnek; gerçek değerleri Coolify panelinde gir, repo'ya commit ETME.
# ============================================================================

# --- HER SERVISTE ORTAK ---
PMS_NEXT_STANDALONE=1

# --- SHARED SECRET (dashboard <-> provisioner) ---
# Üret: openssl rand -hex 32 (veya node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
# Aynı değer hem dashboard hem provisioner Coolify env'lerine yapıştırılır. Repo'ya commit ETME.
PMS_PROVISIONER_TOKEN=<replace-with-32-byte-hex-secret>

# --- preview-sandbox ---
PMS_PREVIEW_PARENT_ORIGIN=https://sites.innovmar.cloud

# --- dashboard ---
NEXT_PUBLIC_PREVIEW_URL=https://preview.innovmar.cloud/preview
NEXT_PUBLIC_ROOT_DOMAIN=innovmar.cloud
PMS_PROVISIONER_URL=https://provisioner.innovmar.cloud
# PMS_PROVISIONER_TOKEN — yukarıdaki shared secret

# --- provisioner ---
PORT=4200
# PMS_PROVISIONER_TOKEN — yukarıdaki shared secret

# GitHub (PAT scope: repo, workflow)
GITHUB_TOKEN=                        # ← gh.com/settings/tokens
GITHUB_ORG=sserdarb                  # ya da pms-sites org açılırsa onu yaz
GITHUB_TEMPLATE_OWNER=sserdarb
GITHUB_TEMPLATE_REPO=site-template

# Cloudflare (Token: Zone.Zone Read + Zone.DNS Edit, scope: innovmar.cloud zone)
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_ROOT_DOMAIN=innovmar.cloud
CLOUDFLARE_PROXY_TARGET=76.13.0.113

# Coolify (zaten memory'de — Coolify panelinden de doğrulanabilir)
COOLIFY_API_URL=https://innovmar.cloud/api/v1
COOLIFY_API_TOKEN=                   # 40|EVTq... (memory'den)
COOLIFY_SERVER_UUID=cwg0w40g0080wcgwo4wog08g
COOLIFY_PROJECT_UUID=                # ← yeni "pms-sites" projesi açılınca
